generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ACTIVE
  BLOCKED
  SUSPENDED
  TRIAL
  CANCELED
  DELINQUENT
}

enum UserStatus {
  ACTIVE
  INVITED
  BLOCKED
  DISABLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ACCESS
}

enum PatientStatus {
  ACTIVE
  LEAD
  IN_TREATMENT
  INACTIVE
  ARCHIVED
}

enum ConversationChannel {
  WHATSAPP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_ATTENDANCE
  COMPLETED
  CANCELED
  NO_SHOW
  RESCHEDULED
  WALK_IN
  RETURN
}

enum FinancialEntryType {
  INCOME
  EXPENSE
}

enum FinancialEntryStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
  SCHEDULED
}

enum ServiceCardPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Tenant {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  legalName      String?
  cnpj           String?             @unique
  status         TenantStatus        @default(TRIAL)
  primaryColor   String?             @default("#0A3F9A")
  secondaryColor String?             @default("#22C7C7")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  users          User[]
  patients       Patient[]
  professionals  Professional[]
  conversations  Conversation[]
  plans          Plan[]
  appointments   Appointment[]
  financialItems FinancialEntry[]
  serviceBoards  ServiceBoard[]
  agents         Agent[]
  settings       ClinicSettings?
  anamneses      AnamnesisTemplate[]
  contracts      ContractTemplate[]
  accounts       FinancialAccount[]
  chairs         Chair[]
  auditLogs      AuditLog[]
}

model User {
  id              String       @id @default(cuid())
  tenantId        String?
  email           String       @unique
  name            String
  passwordHash    String
  status          UserStatus   @default(INVITED)
  isSuperAdmin    Boolean      @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tenant          Tenant?      @relation(fields: [tenantId], references: [id])
  roles           UserRole[]
  sessions        Session[]
  auditLogs       AuditLog[]
  createdPatients Patient[]    @relation("PatientCreatedBy")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@unique([resource, action])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  refreshToken   String   @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String?
  userId      String?
  module      String
  action      AuditAction
  recordType  String
  recordId    String?
  ipAddress   String?
  userAgent   String?
  previous    Json?
  next        Json?
  result      String?
  createdAt   DateTime    @default(now())
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
}

model Patient {
  id              String         @id @default(cuid())
  tenantId        String
  createdById     String?
  fullName        String
  chartNumber     String?
  cpf             String?
  rg              String?
  email           String?
  phone           String?
  mobilePhone     String?
  whatsappPhone   String?
  birthDate       DateTime?
  status          PatientStatus  @default(ACTIVE)
  planId          String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?          @relation("PatientCreatedBy", fields: [createdById], references: [id])
  plan            Plan?          @relation(fields: [planId], references: [id])
  appointments    Appointment[]
  conversations   Conversation[]
  financialItems  FinancialEntry[]

  @@index([tenantId, fullName])
  @@index([tenantId, cpf])
}

model Professional {
  id            String        @id @default(cuid())
  tenantId      String
  name          String
  email         String?
  phone         String?
  specialty     String?
  roleLabel     String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  financialItems FinancialEntry[]
}

model Plan {
  id             String      @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  isDefault      Boolean     @default(false)
  isInsurance    Boolean     @default(false)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patients       Patient[]
  procedures     PlanProcedure[]
}

model PlanProcedure {
  id             String    @id @default(cuid())
  planId         String
  specialty      String
  name           String
  price          Decimal   @db.Decimal(10, 2)
  cost           Decimal   @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  usesToothFaces Boolean   @default(false)
  notes          String?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())
  plan           Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String              @id @default(cuid())
  tenantId        String
  patientId       String?
  contactName     String
  contactPhone    String
  channel         ConversationChannel @default(WHATSAPP)
  unreadCount     Int                 @default(0)
  isAiEnabled     Boolean             @default(false)
  lastMessageAt   DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient         Patient?            @relation(fields: [patientId], references: [id])
  messages        Message[]

  @@index([tenantId, contactPhone])
}

model Message {
  id              String           @id @default(cuid())
  conversationId  String
  externalId      String?          @unique
  direction       MessageDirection
  status          MessageStatus    @default(PENDING)
  content         String?
  mediaUrl        String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  patientId      String
  professionalId String
  title          String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient        Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional   Professional      @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model FinancialEntry {
  id             String               @id @default(cuid())
  tenantId       String
  patientId      String?
  professionalId String?
  description    String
  type           FinancialEntryType
  status         FinancialEntryStatus @default(PENDING)
  category       String
  paymentMethod  String
  amount         Decimal              @db.Decimal(10, 2)
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient        Patient?             @relation(fields: [patientId], references: [id])
  professional   Professional?        @relation(fields: [professionalId], references: [id])
}

model ServiceBoard {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  columns     ServiceColumn[]
}

model ServiceColumn {
  id          String        @id @default(cuid())
  boardId     String
  name        String
  color       String?
  position    Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  board       ServiceBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards       ServiceCard[]
}

model ServiceCard {
  id             String              @id @default(cuid())
  columnId       String
  tenantId       String
  patientId      String?
  professionalId String?
  title          String
  description    String
  priority       ServiceCardPriority @default(NORMAL)
  dueDate        DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  column         ServiceColumn       @relation(fields: [columnId], references: [id], onDelete: Cascade)
}

model Agent {
  id              String       @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  whatsappNumber  String
  model           String
  temperature     Float        @default(0.2)
  promptBase      String
  initialMessage  String?
  status          AgentStatus  @default(DRAFT)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ClinicSettings {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  clinicName      String
  legalName       String?
  email           String?
  phone           String?
  whatsapp        String?
  logoUrl         String?
  primaryColor    String?   @default("#0A3F9A")
  secondaryColor  String?   @default("#22C7C7")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AnamnesisTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  specialty   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, name])
}

model ContractTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  content     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, name])
}

model FinancialAccount {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  bank           String?
  agency         String?
  account        String?
  type           String
  initialBalance Decimal  @default(0) @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, name])
}

model Chair {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  room        String?
  color       String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, name])
}
